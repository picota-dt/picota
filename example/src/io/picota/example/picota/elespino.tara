dsl Picota

Reality elEspino //World
	ViewPoint(period = 1, periodScale = Minute) weather //ViewPoint
		Variable temperature as Numeric
		Variable humidity as Numeric //Dimension facet
	Entity grid //Entity
		ViewPoint(period = 1, periodScale = Hour) energy //viewPoint
			Variable watts as Numeric

DigitalTwin(elEspino.grid) elEspinoDT as Predictive(timeHorizon = 1, timeHorizonScale = Hour)
	Infer(elEspino.grid.energy.watts) //Resolución


