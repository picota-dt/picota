dsl Picota

Reality elEspino //World
	Variable temperature as Numeric
	Variable humidity as Numeric //Dimension facet
	Subject grid //Entity
		Variable watts as Numeric

DigitalTwin(elEspino.grid) Espino-Twin as Predictive(timeHorizon = 1, lag = 1)
	Resolution(1,Minute)
	Infer(elEspino.grid.watts) //Resolución


